# Keep shareable VS Code workspace config in git
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# Other editor-local settings
.idea/
*.code-workspace

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini

# Local environment and machine-specific config
.env
.env.*
!.env.example
!.env.sample
*.local

# Runtime logs and temporary files
*.log
*.log.*
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
error_log
php_errors.log

# Local PHP runtime artifacts generated by contact-handler.php
/contact-log.txt
/rate-limit.log
